ARG BACKEND_PYTHON_IMAGE=python:3.10-slim-bullseye@sha256:f1fb49e4d5501ac93d0ca519fb7ee6250842245aba8612926a46a0832a1ed089

FROM ${BACKEND_PYTHON_IMAGE} AS dist-build
WORKDIR /work
COPY .cache/backend-worktree /work/src/backend
COPY images/backend/scripts /work/images/backend/scripts
RUN set -eux; \
    test -f /work/src/backend/mlflow/server/js/build/index.html; \
    bash /work/images/backend/scripts/apt-install.sh ca-certificates git; \
    python3 -m pip install --no-cache-dir --upgrade pip build setuptools wheel; \
    bash /work/images/backend/scripts/build-distributions.sh /work/src/backend /work/dist; \
    bash /work/images/backend/scripts/smoke-release-install.sh /work/dist

FROM ${BACKEND_PYTHON_IMAGE} AS runtime
WORKDIR /work
ARG BACKEND_BASE_EXTRAS=extras,auth,azure,db,gateway,genai
ARG BACKEND_OVERLAY_EXTRAS=
ENV BACKEND_BASE_EXTRAS=${BACKEND_BASE_EXTRAS}
ENV BACKEND_OVERLAY_EXTRAS=${BACKEND_OVERLAY_EXTRAS}
COPY .cache/backend-worktree /work/src/backend
COPY images/backend/scripts /work/images/backend/scripts
RUN set -eux; \
    test -f /work/src/backend/mlflow/server/js/build/index.html; \
    bash /work/images/backend/scripts/apt-install.sh ca-certificates git; \
    python3 -m pip install --no-cache-dir --upgrade pip setuptools wheel; \
    bash /work/images/backend/scripts/install-full-from-source.sh /work/src/backend; \
    install -m 0755 /work/images/backend/scripts/ai_models_backend_runtime.py /usr/local/bin/ai_models_backend_runtime.py; \
    install -m 0755 /work/images/backend/scripts/ai_models_backend_runtime.py /usr/local/bin/ai-models-backend-runtime; \
    install -m 0755 /work/images/backend/scripts/ai-models-backend-db-upgrade.py /usr/local/bin/ai-models-backend-db-upgrade; \
    install -m 0755 /work/images/backend/scripts/ai-models-backend-bootstrap-oidc-auth.py /usr/local/bin/ai-models-backend-bootstrap-oidc-auth; \
    install -m 0755 /work/images/backend/scripts/ai-models-backend-hf-import.py /usr/local/bin/ai-models-backend-hf-import; \
    python3 -m pip install --no-cache-dir "mlflow-oidc-auth==6.7.1"; \
    python3 -m pip install --no-cache-dir \
      "transformers<5" \
      "huggingface-hub>=0.10.0" \
      sentencepiece \
      safetensors; \
    printf '%s\n' \
      '#!/bin/sh' \
      'set -eu' \
      '[ -n "${AI_MODELS_S3_ENDPOINT_URL:-}" ] && export MLFLOW_S3_ENDPOINT_URL="${AI_MODELS_S3_ENDPOINT_URL}"' \
      '[ -n "${AI_MODELS_S3_IGNORE_TLS:-}" ] && export MLFLOW_S3_IGNORE_TLS="${AI_MODELS_S3_IGNORE_TLS}"' \
      'exec mlflow "$@"' \
      >/usr/local/bin/ai-models-backend; \
    chmod +x /usr/local/bin/ai-models-backend; \
    bash /work/images/backend/scripts/smoke-runtime.sh; \
    rm -rf /root/.cache /work/src/backend /work/images
ENTRYPOINT ["ai-models-backend"]
CMD ["server", "--help"]
