 # Global flag to track OIDC initialization status for health checks
 _oidc_initialized: bool = False
 
+WORKSPACE_QUERY_PARAMETER = "workspace"
+WORKSPACE_AWARE_PATH_PREFIXES = (
+    "/oidc/",
+    "/api/2.0/mlflow/permissions/",
+    "/api/2.0/mlflow/users",
+    "/api/3.0/mlflow/permissions/",
+)
 
+
+def _is_workspace_aware_path(path: str) -> bool:
+    return any(path.startswith(prefix) for prefix in WORKSPACE_AWARE_PATH_PREFIXES)
+
+
+def _resolve_workspace_hint(scope: Scope) -> str | None:
+    header_value = Headers(scope=scope).get(WORKSPACE_HEADER_NAME)
+    if header_value:
+        return header_value
+
+    raw_query = scope.get("query_string", b"")
+    if not raw_query:
+        return None
+
+    params = parse_qs(raw_query.decode("utf-8", errors="ignore"))
+    values = params.get(WORKSPACE_QUERY_PARAMETER)
+    if not values:
+        return None
+
+    workspace = values[0].strip()
+    return workspace or None
+
+
+def _workspace_error_response(exc: MlflowException) -> Response:
+    return Response(
+        content=exc.serialize_as_json(),
+        media_type="application/json",
+        status_code=exc.get_http_status_code(),
+    )
+
+
+class WorkspaceContextMiddleware:
+    def __init__(self, app: ASGIApp):
+        self.app = app
+
+    async def __call__(self, scope: Scope, receive: Receive, send: Send) -> None:
+        if scope["type"] != "http":
+            await self.app(scope, receive, send)
+            return
+
+        path = scope.get("path", "")
+        if not _is_workspace_aware_path(path):
+            await self.app(scope, receive, send)
+            return
+
+        try:
+            workspace = resolve_workspace_for_request_if_enabled(path, _resolve_workspace_hint(scope))
+        except MlflowException as exc:
+            await _workspace_error_response(exc)(scope, receive, send)
+            return
+
+        workspace_context.set_server_request_workspace(workspace.name if workspace else None)
+        try:
+            await self.app(scope, receive, send)
+        finally:
+            workspace_context.clear_server_request_workspace()
+
